# ===========================================
# Mattermost Configuration
# ===========================================

# --- Docker Images ---
# Pin to a specific digest for reproducibility:
# Example: ghcr.io/OWNER/mattermost-vendor:latest@sha256:<digest>
MATTERMOST_IMAGE=ghcr.io/korjavin/mattermost-vendor:latest
# Upstream: mattermost/mattermost-enterprise-edition:release-10.5

# Pin postgres image:
# Example: ghcr.io/korjavin/mattermost-postgres-vendor:latest@sha256:<digest>
POSTGRES_IMAGE=ghcr.io/korjavin/mattermost-postgres-vendor:latest
# Upstream: postgres:16-alpine

# --- Container Names ---
MATTERMOST_CONTAINER_NAME=mattermost
DB_CONTAINER_NAME=mattermost-db

# --- Network Names ---
TRAEFIK_NETWORK_NAME=traefik_default
INTERNAL_NETWORK_NAME=mattermost_internal

# --- Volume Names ---
DB_VOLUME_NAME=mattermost_db-data

# --- Traefik Configuration ---
MATTERMOST_HOST=mattermost.yourdomain.com
TRAEFIK_CERTRESOLVER=myresolver

# --- General ---
TIMEZONE=UTC

# --- Mattermost Data Paths ---
# These bind-mount paths must be owned by UID/GID 2000:2000
# Run: sudo chown -R 2000:2000 ./volumes/mattermost
MATTERMOST_CONFIG_PATH=./volumes/mattermost/config
MATTERMOST_DATA_PATH=./volumes/mattermost/data
MATTERMOST_LOGS_PATH=./volumes/mattermost/logs
MATTERMOST_PLUGINS_PATH=./volumes/mattermost/plugins
MATTERMOST_CLIENT_PLUGINS_PATH=./volumes/mattermost/client/plugins
MATTERMOST_BLEVE_INDEXES_PATH=./volumes/mattermost/bleve-indexes

# --- Database ---
POSTGRES_DB=mattermost
POSTGRES_USER=mattermost
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=change-me-to-strong-password
