# ===========================================
# Mattermost Configuration
# ===========================================

# --- Docker Images ---
# Pin to a specific digest for reproducibility:
# Example: ghcr.io/OWNER/mattermost-vendor:latest@sha256:<digest>
MATTERMOST_IMAGE=ghcr.io/korjavin/mattermost-vendor:latest
# Upstream: mattermost/mattermost-team-edition:latest

# Pin postgres image:
# Example: ghcr.io/korjavin/mattermost-postgres-vendor:latest@sha256:<digest>
POSTGRES_IMAGE=ghcr.io/korjavin/mattermost-postgres-vendor:latest
# Upstream: postgres:16-alpine

# --- Container Names ---
MATTERMOST_CONTAINER_NAME=mattermost
DB_CONTAINER_NAME=mattermost-db

# --- Network Names ---
TRAEFIK_NETWORK_NAME=traefik_default
INTERNAL_NETWORK_NAME=mattermost_internal

# --- Volume Names ---
DB_VOLUME_NAME=mattermost_db-data

# --- Traefik Configuration ---
MATTERMOST_HOST=mattermost.yourdomain.com
TRAEFIK_CERTRESOLVER=myresolver

# --- General ---
TIMEZONE=UTC

# --- Mattermost Data Paths ---
# These bind-mount paths must be owned by UID/GID 2000:2000
# Run: sudo chown -R 2000:2000 ./volumes/mattermost
MATTERMOST_CONFIG_PATH=./volumes/mattermost/config
MATTERMOST_DATA_PATH=./volumes/mattermost/data
MATTERMOST_LOGS_PATH=./volumes/mattermost/logs
MATTERMOST_PLUGINS_PATH=./volumes/mattermost/plugins
MATTERMOST_CLIENT_PLUGINS_PATH=./volumes/mattermost/client/plugins
MATTERMOST_BLEVE_INDEXES_PATH=./volumes/mattermost/bleve-indexes

# --- Database ---
POSTGRES_DB=mattermost
POSTGRES_USER=mattermost
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=change-me-to-strong-password

# ===========================================
# Optional: Restic Backups (mattermost-backup sidecar)
# ===========================================
# Backs up the Postgres DB (pg_dump) + the file store to any restic backend.
# DISABLED by default. Enable by adding 'backup' to COMPOSE_PROFILES:
#COMPOSE_PROFILES=backup

# Backup image (built + pushed by .github/workflows/build-backup-image.yml)
BACKUP_IMAGE=ghcr.io/korjavin/mattermost-backup:latest
BACKUP_CONTAINER_NAME=mattermost-backup
BACKUP_CACHE_VOLUME_NAME=mattermost_backup-cache

# restic repository (backend-agnostic). Examples:
#   Backblaze B2: b2:my-bucket:mattermost
#   S3-compatible: s3:s3.us-west-001.backblazeb2.com/my-bucket/mattermost
#   SFTP: sftp:user@host:/srv/restic/mattermost
RESTIC_REPOSITORY=
# Repo encryption key — generate with: openssl rand -hex 32
# KEEP THIS SAFE AND OFF-SERVER: without it, backups are unrecoverable.
RESTIC_PASSWORD=

# Backend credentials — set ONLY the pair matching your RESTIC_REPOSITORY:
# Backblaze B2 (b2: backend):
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
# S3-compatible (s3: backend):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Schedule & retention (GFS)
BACKUP_INTERVAL_SECONDS=86400
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6
